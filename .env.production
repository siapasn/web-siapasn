#--------------------------------------------------------------------
# SiapASN Simulation Center - PRODUCTION Environment
#
# CARA PAKAI:
# 1. Copy file ini menjadi .env di hosting
# 2. Isi semua nilai yang bertanda <<GANTI>>
# 3. Upload ke public_html/ di cPanel
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://siapasnsimulationcenter.id/'
app.name    = 'SiapASN Simulation Center'
app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

app.sessionExpiration = 3600

#--------------------------------------------------------------------
# DATABASE
# Isi sesuai database yang dibuat di cPanel → MySQL Databases
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = siah2794_siapasn
database.default.username = siah2794_root
database.default.password = Windows7!!!
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

#--------------------------------------------------------------------
# EMAIL SMTP
#--------------------------------------------------------------------

email.host       = mail.siapasnsimulationcenter.id
email.port       = 465
email.username   = noreply@siapasnsimulationcenter.id
email.password   = "Windows7!!!"
email.encryption = ssl
email.from       = noreply@siapasnsimulationcenter.id
email.from_name  = 'SiapASN Simulation Center'
email.timeout    = 10

#--------------------------------------------------------------------
# LOGGER — production hanya catat error
#--------------------------------------------------------------------

logger.threshold = 4
