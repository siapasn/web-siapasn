# ============================================================
# SiapASN Simulation Center — Root .htaccess
# Untuk shared hosting (Rumah Web / cPanel / Apache)
#
# Cara deploy:
# 1. Upload SEMUA file project ke public_html/
# 2. File ini + index.php di root akan handle routing
# ============================================================

<IfModule mod_rewrite.c>
    Options +FollowSymlinks
    RewriteEngine On

    # Jika request menuju file/folder yang benar-benar ada (aset, dll.) — biarkan
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Jika request menuju file/folder di dalam public/ — layani langsung
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/public/%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L]

    # Semua request lain → index.php di root (yang akan forward ke public/index.php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 /index.php
</IfModule>

# Keamanan — blokir akses langsung ke folder sensitif
<IfModule mod_rewrite.c>
    RewriteRule ^(app|vendor|writable|tests|build)(/.*)?$ - [F,L]
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^spark$ - [F,L]
</IfModule>

# Disable directory listing
Options -Indexes

# Sembunyikan server signature
ServerSignature Off
